[pylint]
# for the unittests disable some pylint warnings, e.g. we don't want to force devs to write docstrings for every test
disable =
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring
    R0903,  # too-few-public-methods
    W0621,  # redefined-outer-name (pytest fixtures)
    R0801,  # duplicate-code (tests prefer explicit over DRY)
    C1803,  # use-implicit-booleaness-not-comparison (== [] is clearer in tests)
    W0201,  # attribute-defined-outside-init (setup_method sets attrs)
    C0415,  # import-outside-toplevel (scoped imports are sometimes intentional)
load-plugins = pylint_pydantic
[pylint."MESSAGES CONTROL"]
max-line-length = 120